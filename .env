# DBCode zero-config auto-detects this file in the workspace root and adds the
# connection automatically (it shows up with a compass 🧭 icon). No manual setup.
# See: https://dbcode.io/docs/connections/zero-config
#
# Host is `postgres` (the sibling compose service) so this resolves inside the
# devcontainer. NOTE: on the host, use `localhost` instead of `postgres`.
DATABASE_URL=postgres://graph:graphpass@postgres:5432/graphlab
