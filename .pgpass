# PostgreSQL password file — format: hostname:port:database:username:password
# DBCode can read this as an authentication profile so the password never lives
# in the connection itself.  https://dbcode.io/docs/authentication-profiles/pgpass
#
# In DBCode: create an Authentication Profile -> pgpass -> point it at THIS file,
# then attach it to the connection. Must be chmod 600 or libpq/DBCode ignores it.
localhost:5432:graphlab:graph:graphpass
